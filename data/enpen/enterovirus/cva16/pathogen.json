{
  "$schema": "https://raw.githubusercontent.com/nextstrain/nextclade/refs/heads/release/packages/nextclade-schemas/input-pathogen-json.schema.json",
  "schemaVersion": "3.0.0",
  "files": {
    "reference": "reference.fasta",
    "pathogenJson": "pathogen.json",
    "genomeAnnotation": "genome_annotation.gff3",
    "treeJson": "tree.json",
    "examples": "sequences.fasta",
    "readme": "README.md",
    "changelog": "CHANGELOG.md"
  },
  "attributes": {
    "name": "Coxsackievirus A16",
    "reference name": "Coxsackievirus A16",
    "reference accession": "U05876.1"
  },
  "alignmentParams": {
        "penaltyGapOpen": 13,
        "penaltyGapExtend": 1,
        "penaltyGapOpenInFrame": 18,
        "penaltyGapOpenOutOfFrame": 23,
        "kmerLength": 6,
        "kmerDistance": 25,
        "minMatchLength": 30,
        "allowedMismatches": 15,
        "minLength": 100,
        "minSeedCover": 0.30,
        "gapAlignmentSide":"left"
    },
  "defaultCds": "VP1",
  "compatibility": {
        "cli": "3.0.0",
        "web": "3.0.0"
    },
  "mutLabels": {
  "aaMutLabelMap": {
  },
  "nucMutLabelMap": {
    }
  },
  "qc": {
    "frameShifts": {
      "enabled": true,
      "scoreWeight": 100
    },
    "missingData": {
      "enabled": true,
      "missingDataThreshold": 1000,
      "scoreBias": 100
    },
    "mixedSites": {
      "enabled": true,
      "mixedSitesThreshold": 10
    },
    "privateMutations": {
      "enabled": true,
      "cutoff": 120,
      "typical": 40,
      "weightLabeledSubstitutions": 1.5,
      "weightReversionSubstitutions": 2,
      "weightUnlabeledSubstitutions": 1
    },
    "divergence": {
      "enabled": true,
      "maxDivergence": 0.15,
      "scoreWeight": 50
    },
    "stopCodons": {
      "enabled": true,
      "scoreWeight": 60
    },
    "snpClusters": {
      "enabled": true,
      "windowSize": 100,
      "clusterCutOff": 4,
      "scoreWeight": 25
    },
      "cdsOrderPreference": [
        "VP4","VP2","VP3","VP1",
        "2A","2B","2C",
        "3A","3B","3C","3D"
      ]
    }
  }